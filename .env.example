# ─── Portfolio Backend — Environment Variables ───────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to git.

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000

# The URL of your React frontend (used for CORS whitelisting).
# In development this will be http://localhost:5173.
# In production, replace with your deployed frontend URL.
FRONTEND_ORIGIN=http://localhost:5173

# ── MongoDB Atlas ─────────────────────────────────────────────────────────────
# Your full Atlas connection string. Replace <db_username> and <db_password>.
MONGODB_URI=mongodb+srv://<db_username>:<db_password>@cluster0.mdggl3p.mongodb.net/?appName=Cluster0

# ── Email (Nodemailer + Gmail) ────────────────────────────────────────────────
# The Gmail address that SENDS the email (your Gmail account).
EMAIL_USER=your_gmail_address@gmail.com

# A Gmail App Password — NOT your regular Gmail password.
# Steps to generate one:
#   1. Go to your Google Account → Security
#   2. Enable 2-Step Verification (required)
#   3. Search for "App Passwords" in the search bar
#   4. Select "Mail" as the app and "Windows Computer" as the device
#   5. Click "Generate" and paste the 16-character code below (no spaces)
EMAIL_PASS=your_16_character_app_password

# The Gmail address that RECEIVES the contact form submissions.
EMAIL_RECEIVER=aggarwalagrim72@gmail.com
